{
  "type": "record",
  "name": "Order",
  "namespace": "com.demo.avro",
  "fields": [
    { "name": "id",       "type": "string" },
    { "name": "amount",   "type": "double" },
    { "name": "currency", "type": "string", "default": "USD" },
    { "name": "status",   "type": "string", "default": "CREATED" }
  ]
}